---
import '../styles/globals.css';
import ThemeToggle from '../components/ThemeToggle.tsx';

interface Props {
  title?: string;
}
const { title = 'Analytics' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const v = localStorage.getItem('theme');
        const dark = v === 'dark' || (v == null && matchMedia('(prefers-color-scheme: dark)').matches);
        if (dark) document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <header class="border-b border-border bg-card/50 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
        <h1 class="text-lg font-semibold">Proxy Gateway Analytics</h1>
        <ThemeToggle client:only="react" />
      </div>
    </header>
    <main class="max-w-7xl mx-auto px-6 py-8">
      <slot />
    </main>
  </body>
</html>
