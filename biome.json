{
    "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
    "files": {
        "includes": [
            "proxy-gateway-client-ts/**",
            "analytics-service/**",
            "!analytics-service/node_modules/**",
            "!analytics-service/dist/**",
            "!analytics-service/.astro/**",
            "!analytics-service/src/server/gen/**",
            "!analytics-service/**/*.astro"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "assist": {
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "trailingCommas": "all"
        }
    },
    "json": {
        "formatter": {
            "expand": "auto"
        }
    },
    "css": {
        "parser": {
            "cssModules": false,
            "tailwindDirectives": true
        },
        "formatter": {
            "enabled": true
        }
    },
    "overrides": [
        {
            "includes": ["analytics-service/**"],
            "formatter": {
                "indentWidth": 2,
                "lineWidth": 100
            },
            "javascript": {
                "formatter": {
                    "quoteStyle": "single",
                    "trailingCommas": "all"
                }
            }
        }
    ]
}
